# Copy to .env.local for local dev, or set these in Vercel → Project → Settings → Environment Variables.

# Your OpenAI API key (server-side only, never exposed to clients).
OPENAI_API_KEY=sk-REPLACE_ME

# A long random string YOU invent. Used as the shared secret in the connector URL (?k=...).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# Auto-added by Vercel when you enable Blob storage on the project. Needed for local dev only.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Optional: override the image model.
# OPENAI_IMAGE_MODEL=gpt-image-1.5
